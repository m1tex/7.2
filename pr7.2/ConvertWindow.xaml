<Window x:Class="pr7._2.ConvertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr7._2"
        mc:Ignorable="d"
        Title="ConvertWindow" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" Foreground="#FFDE88FF">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF88713C" Offset="1"/>
            <GradientStop Color="#FF786334" Offset="0.883"/>
            <GradientStop Color="#FF335875" Offset="0.583"/>
            <GradientStop Color="#FF4F4C5D" Offset="0.693"/>
            <GradientStop Color="#FF072033" Offset="0.273"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Name ="label2" Grid.Row ="0" Grid.Column="0" Content="Enter a decimal number" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Red" BorderBrush="Red"/>
        <TextBox Name ="textBoxForInput" Grid.Row ="0" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Width="100" Foreground="Red" Background="{x:Null}" BorderBrush="Red"/>
        <GroupBox Name ="groupBoxNumSys" Header="Number System" Grid.Row="1" Grid.ColumnSpan="2" Foreground="Red" BorderBrush="Red">
            <StackPanel Orientation="Horizontal" Margin="5">
                <RadioButton Name ="radBtnFor2" Content="2" GroupName="Base" IsChecked="True" Margin="10,0" Foreground="Red" BorderBrush="White" Background="#FFEA0000"/>
                <RadioButton Name ="radBtnFor8" Content="8" GroupName="Base" Margin="120,0" Foreground="Red" BorderBrush="White" Background="Red"/>
                <RadioButton Name ="radBtnFor16" Content="16" GroupName="Base" Margin="10,0" Foreground="Red" BorderBrush="White" Background="Red"/>
            </StackPanel>
        </GroupBox>
        <Label Name ="label3" Grid.Row ="2" Grid.ColumnSpan="2" Content="Result" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Red"/>
        <Label Name ="labelResult" Grid.Row ="3" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Red" Background="{x:Null}" Width="100" Height="30"/>
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Vertical">
            <Button Name ="btnDo" Content="Do" Width="70" Height="30" Margin="80, 20" HorizontalAlignment="Left" Foreground="Red" Background="{x:Null}" BorderBrush="Red" Click="DoClick"/>
            <Button Name ="btnOk" Content="Ok" Width="70" Height="30" Margin="0, -50 ,90, 20" HorizontalAlignment="Right" Background="{x:Null}" Foreground="Red" BorderBrush="Red" IsDefault="True" Click="okClick"/>

        </StackPanel>
    </Grid>
</Window>
