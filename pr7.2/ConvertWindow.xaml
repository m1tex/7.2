<Window x:Class="pr7._2.ConvertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr7._2"
        mc:Ignorable="d"
        Title="ConvertWindow" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" Foreground="#FFDE88FF">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Name ="label2" Grid.Row ="0" Grid.Column="0" Content="Input:" Margin="122,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="White" BorderBrush="White" Background="{x:Null}" FontSize="18" Height="37"/>
        <TextBox Name ="textBoxForInput" Grid.Row ="0" Grid.Column="1" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" Width="100" Foreground="White" Background="{x:Null}" BorderBrush="White" FontSize="18"/>
        <GroupBox Name ="groupBoxNumSys" Header="Number System" Grid.Row="1" Grid.ColumnSpan="2" Foreground="White" BorderBrush="White" FontSize="18">
            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                <RadioButton Name ="radBtnFor2" Content="2" GroupName="Base" IsChecked="True"  Foreground="White" BorderBrush="Black" Background="White" Height="25" Width="35"/>
                <RadioButton Name ="radBtnFor8" Content="8" GroupName="Base" Margin="100,0" Foreground="White" BorderBrush="Black" Background="White" Height="25" Width="45" HorizontalAlignment="Center"/>
                <RadioButton Name ="radBtnFor16" Content="16" GroupName="Base"  Foreground="White" BorderBrush="Black" Background="White" Height="25" Width="50"/>
            </StackPanel>
        </GroupBox>
        <Label Name ="label3" Grid.Row ="2" Grid.ColumnSpan="2" Content="Result:" Margin ="120,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Black" FontSize="18"/>
        <Label Name ="labelResult" Grid.Row ="2" Grid.ColumnSpan="2" Margin ="190,-3,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Black" Background="{x:Null}" Width="100" Height="30" HorizontalContentAlignment="Center" FontSize="18"/>
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Vertical">
            <Button Name ="btnDo" Content="Do" Width="70" Height="30" Margin="80, 20" HorizontalAlignment="Left" Foreground="Black" Background="{x:Null}" BorderBrush="Black" Click="DoClick" FontSize="18"/>
            <Button Name ="btnOk" Content="Ok" Width="70" Height="30" Margin="0, -50 ,90, 20" HorizontalAlignment="Right" Background="{x:Null}" Foreground="Black" BorderBrush="Black" IsDefault="True" Click="OkClick" FontSize="18"/>

        </StackPanel>
    </Grid>
</Window>
