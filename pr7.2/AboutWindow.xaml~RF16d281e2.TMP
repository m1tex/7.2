<Window x:Class="pr7._2.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr7._2"
        mc:Ignorable="d"
        Title="About" Height="400" Width="400" Background="#FFB38156"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="50,0,48,0" Height="225">
            <Label Content="pr7.2" Width="100" Height="30" HorizontalContentAlignment="Center"/>
            <Label Content="Galov K." Width="100" Height="30" HorizontalContentAlignment="Center" Margin="0,50,0,0"/>
            <TextBlock Background="{x:Null}" Foreground="#FF1300FF" VerticalAlignment="Center" HorizontalAlignment="Center">
                  <Hyperlink NavigateUri="galov.kirya@gmail.com"
                       RequestNavigate="Hyperlink_RequestNavigate">
                galov.kirya@gmail.com
            </Hyperlink>
            </TextBlock>
        </StackPanel>
        <Button Name ="btnBack" Content="Back" HorizontalAlignment="Left" Margin="20,19,0,0" VerticalAlignment="Top" Click="" Background="{x:Null}" Foreground="Red" BorderBrush="Red"/>

    </Grid>
</Window>
